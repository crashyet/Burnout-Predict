{
  "openapi": "3.0.0",
  "info": {
    "title": "NodeJS Burnout Predict Backend API Docs",
    "version": "1.0.0",
    "description": "API untuk mengelola data user, daily check-in (yang berintegrasi dengan ML & Gemini untuk prediksi burnout), log jurnal harian, dan kesehatan sistem."
  },
  "servers": [
    {
      "url": "https://burnout-predict.vercel.app/api/v1",
      "description": "Production Server"
    },
    {
      "url": "http://localhost:5000/api/v1",
      "description": "Local Development Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Pendaftaran Pengguna Baru",
        "description": "Membuat akun pengguna baru. Mengirimkan 6-digit kode OTP ke email pengguna untuk verifikasi.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password"],
                "properties": {
                  "name": { "type": "string", "example": "Adhitya" },
                  "email": { "type": "string", "format": "email", "example": "user@example.com" },
                  "password": { "type": "string", "example": "password123" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Registrasi berhasil, OTP dikirim.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "message": { "type": "string", "example": "User registered. Please check your email for the 6-digit OTP." },
                    "data": {
                      "type": "object",
                      "properties": {
                        "email": { "type": "string", "example": "user@example.com" }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Email sudah terdaftar atau format input tidak valid."
          }
        }
      }
    },
    "/auth/verify-otp": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Verifikasi Akun dengan OTP",
        "description": "Memverifikasi email pendaftaran menggunakan 6 digit kode OTP. Mengembalikan token JWT jika berhasil.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "user@example.com" },
                  "otp": { "type": "string", "example": "123456", "description": "Bisa dikirim sebagai 'otp' atau 'otp_code'" },
                  "otp_code": { "type": "string", "example": "123456" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Verifikasi akun berhasil, JWT token dikembalikan.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "message": { "type": "string", "example": "Email verified successfully." },
                    "data": {
                      "type": "object",
                      "properties": {
                        "token": { "type": "string", "example": "eyJhbGciOiJIUzI1Ni..." },
                        "user": {
                          "type": "object",
                          "properties": {
                            "id": { "type": "integer", "example": 12 },
                            "name": { "type": "string", "example": "Adhitya" },
                            "email": { "type": "string", "example": "user@example.com" }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "OTP salah atau kedaluwarsa."
          }
        }
      }
    },
    "/auth/resend-otp": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Kirim Ulang Kode OTP",
        "description": "Mengirimkan ulang kode OTP baru ke email terdaftar yang belum terverifikasi.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "user@example.com" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP baru berhasil dikirim.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "message": { "type": "string", "example": "A new OTP has been sent to your email." },
                    "data": {
                      "type": "object",
                      "properties": {
                        "email": { "type": "string", "example": "user@example.com" }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Permintaan tidak valid atau email sudah terverifikasi."
          },
          "404": {
            "description": "Email tidak terdaftar."
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Masuk / Login Pengguna",
        "description": "Melakukan autentikasi menggunakan email dan password untuk mendapatkan token JWT. Jika akun belum diverifikasi, akan dikirimkan OTP baru dan mengembalikan error status 401 dengan informasi unverified.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "user@example.com" },
                  "password": { "type": "string", "example": "password123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Autentikasi berhasil.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "message": { "type": "string", "example": "Login successful" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "token": { "type": "string", "example": "eyJhbGciOiJIUzI1Ni..." },
                        "user": {
                          "type": "object",
                          "properties": {
                            "id": { "type": "integer", "example": 12 },
                            "name": { "type": "string", "example": "Adhitya" },
                            "email": { "type": "string", "example": "user@example.com" }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Kredensial salah ATAU akun belum terverifikasi.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "error" },
                    "message": { "type": "string", "example": "Please verify your email before logging in" },
                    "errors": {
                      "type": "object",
                      "properties": {
                        "unverified": { "type": "boolean", "example": true },
                        "email": { "type": "string", "example": "user@example.com" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/journal": {
      "post": {
        "tags": ["Journaling"],
        "summary": "Buat Entri Jurnal Harian Baru",
        "description": "Menyimpan catatan jurnal harian. Teks jurnal akan dianalisis menggunakan model ML untuk mendeteksi emosi, dan Gemini AI digunakan untuk memicu respon motivasi/empati sesuai emosi dominan yang terdeteksi.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["content"],
                "properties": {
                  "content": { "type": "string", "example": "Hari ini beban kerja saya sangat berat dan saya merasa stress sekali karena kurang tidur." }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Jurnal berhasil disimpan dan dianalisis.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "message": { "type": "string", "example": "Journal entry created" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "integer", "example": 12 },
                        "content": { "type": "string", "example": "Hari ini beban kerja saya..." },
                        "mood_expression": { "type": "string", "example": "sadness" },
                        "emotions": {
                          "type": "object",
                          "properties": {
                            "sadness": { "type": "number", "example": 0.954 },
                            "anger": { "type": "number", "example": 0.035 },
                            "fear": { "type": "number", "example": 0.011 },
                            "happy": { "type": "number", "example": 0.0 },
                            "love": { "type": "number", "example": 0.0 }
                          }
                        },
                        "motivations": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "emotion": { "type": "string", "example": "sadness" },
                              "message": { "type": "string", "example": "Sangat wajar jika kamu merasa lelah..." }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["Journaling"],
        "summary": "Ambil Riwayat Jurnal Pengguna",
        "description": "Mengambil daftar seluruh jurnal harian pengguna beserta hasil deteksi emosi dan motivasinya. Mendukung limitasi data.",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Batas jumlah jurnal terakhir yang ingin ditampilkan.",
            "required": false,
            "schema": {
              "type": "integer",
              "example": 5
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Daftar jurnal berhasil diambil.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "message": { "type": "string", "example": "Journals retrieved" },
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "integer", "example": 12 },
                          "user_id": { "type": "integer", "example": 12 },
                          "content": { "type": "string", "example": "Hari ini beban kerja saya..." },
                          "created_at": { "type": "string", "format": "date-time", "example": "2026-05-28T12:00:00.000Z" },
                          "mood_expression": { "type": "string", "example": "sadness" },
                          "emotions": {
                            "type": "object",
                            "properties": {
                              "sadness": { "type": "number", "example": 0.954 },
                              "anger": { "type": "number", "example": 0.035 }
                            }
                          },
                          "motivations": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "emotion": { "type": "string", "example": "sadness" },
                                "message": { "type": "string", "example": "Sangat wajar jika kamu merasa lelah..." }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/predict": {
      "post": {
        "tags": ["Burnout Prediction & Checkin"],
        "summary": "Catat Daily Check-in & Hitung Prediksi Burnout",
        "description": "Mencatat jam tidur, jam kerja, dan skor assessment/id kuesioner. Memanggil model ML untuk memprediksi tingkat burnout (Low/Moderate/High) serta Gemini AI untuk mendapatkan rekomendasi kesehatan mental.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["sleep_hours", "work_hours"],
                "properties": {
                  "sleep_hours": { "type": "number", "format": "float", "example": 7.5 },
                  "work_hours": { "type": "number", "format": "float", "example": 8.0 },
                  "score_assessment": { "type": "integer", "description": "Skor kuesioner mandiri", "example": 75 },
                  "assessment_id": { "type": "integer", "description": "ID assessment (opsional)", "example": 1 }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Check-in berhasil disimpan dan hasil prediksi burnout dihasilkan.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "message": { "type": "string", "example": "Check-in recorded successfully" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "integer", "example": 1 },
                        "user_id": { "type": "integer", "example": 12 },
                        "sleep_hours": { "type": "number", "example": 7.5 },
                        "work_hours": { "type": "number", "example": 8.0 },
                        "score_assessment": { "type": "integer", "example": 75 },
                        "final_burnout_score": { "type": "number", "example": 68.5 },
                        "final_burnout_level": { "type": "string", "example": "Moderate" },
                        "note": { "type": "string", "example": "Rekomendasi pencegahan burnout..." },
                        "warning": { "type": "string", "example": "Peringatan tren burnout..." },
                        "dashboard_recommendation": { "type": "string", "example": "Rekomendasi keseluruhan..." },
                        "created_at": { "type": "string", "format": "date-time", "example": "2026-05-28T12:00:00.000Z" },
                        "ml_payload": {
                          "type": "object",
                          "properties": {
                            "work_hours_list": { "type": "array", "items": { "type": "number" }, "example": [8.0] },
                            "sleep_hours_list": { "type": "array", "items": { "type": "number" }, "example": [7.5] },
                            "burnout_score_list": { "type": "array", "items": { "type": "number" }, "example": [0] },
                            "questionnaire_score": { "type": "number", "example": 75.0 }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["Burnout Prediction & Checkin"],
        "summary": "Ambil Riwayat Daily Check-in & Prediksi",
        "description": "Mengembalikan semua catatan check-in beserta hasil analisis burnout dari pengguna yang sedang login secara descending.",
        "responses": {
          "200": {
            "description": "Daftar riwayat check-in dan prediksi berhasil diambil.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "message": { "type": "string", "example": "Check-ins retrieved" },
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": { "type": "integer", "example": 1 },
                          "user_id": { "type": "integer", "example": 12 },
                          "sleep_hours": { "type": "number", "example": 7.5 },
                          "work_hours": { "type": "number", "example": 8.0 },
                          "score_assessment": { "type": "integer", "example": 75 },
                          "assessment_score": { "type": "integer", "example": 75 },
                          "final_burnout_score": { "type": "number", "example": 68.5 },
                          "final_burnout_level": { "type": "string", "example": "Moderate" },
                          "note": { "type": "string", "example": "Rekomendasi..." },
                          "warning": { "type": "string", "example": "Peringatan..." },
                          "dashboard_recommendation": { "type": "string", "example": "Rekomendasi dashboard..." },
                          "created_at": { "type": "string", "format": "date-time", "example": "2026-05-28T12:00:00.000Z" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/profile": {
      "get": {
        "tags": ["User Profile"],
        "summary": "Ambil Data Profil User",
        "description": "Mendapatkan detail profil user yang terautentikasi berdasarkan JWT token.",
        "responses": {
          "200": {
            "description": "Data profil user berhasil diakses.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "success" },
                    "message": { "type": "string", "example": "Profile data accessed" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "user": {
                          "type": "object",
                          "properties": {
                            "id": { "type": "integer", "example": 12 },
                            "email": { "type": "string", "example": "user@example.com" }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": ["System Health"],
        "summary": "Cek Kesehatan Layanan API",
        "description": "Memastikan server API berjalan lancar.",
        "security": [],
        "responses": {
          "200": {
            "description": "Server berjalan OK.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "OK", "example": "OK" },
                    "message": { "type": "string", "example": "API is running" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
